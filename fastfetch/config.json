{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "type": "auto",
        "source": "arch",
        "padding": {
            "left": 2,
            "right": 2
        },
        "color": {
            "1": "light_blue",
            "2": "blue"
        }
    },
    "display": {
        "separator": ": ",
        "color": {
            "title": "light_blue",
            "keys": "blue"
        },
        "key": {
            "width": 12,
            "type": "string"
        },
        "bar": {
            "width": 10,
            "char": {
                "elapsed": "■",
                "total": "-"
            }
        },
        "percent": {
            "type": 2,
            "color": {
                "green": "green",
                "yellow": "light_yellow",
                "red": "light_red"
            }
        }
    },
    "modules": [
        "title",
        "break",

        "os",
        "kernel",
        "wm",
        "shell",
        "terminal",
        "packages",
        "break",

        {
            "type": "datetime",
            "key": "DateTime"
        },
        "uptime",
        "processes",
        {
            "type": "cpu",
            "showPeCoreCount": true,
            "temp": true
        },
        {
            "type": "gpu",
            "driverSpecific": true,
            "temp": true,
            "hideType": "integrated"
        },
        {
            "type": "memory",
            "key": "Memory",
            "percent": {
                "green": 30,
                "yellow": 70,
                "red": 90
            }
        },
        {
            "type": "disk",
            "key": "Disk",
            "percent": {
                "green": 30,
                "yellow": 70,
                "red": 90
            }
        },
        "break",

        "colors"
    ]
}
